<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ title or site.title }}</title>
    <meta name="description" content="{{ description or site.description }}" />
    <meta name="author" content="{{ site.author }}" />
    <meta name="keywords" content="{{ keywords or site.keywords }}" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="theme-color" content="#080b10" />
    <link rel="canonical" href="{{ page.url | absoluteUrl(site.url) }}" />
    <meta property="og:title" content="{{ title or site.title }}" />
    <meta property="og:description" content="{{ description or site.description }}" />
    <meta property="og:type" content="{% if page.url and page.url.startsWith('/posts/') %}article{% else %}website{% endif %}" />
    <meta property="og:url" content="{{ page.url | absoluteUrl(site.url) }}" />
    <meta property="og:site_name" content="{{ site.title }}" />
    <meta property="og:locale" content="{{ site.locale }}" />
    <meta property="og:image" content="{{ site.image | absoluteUrl(site.url) }}" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="{{ site.title }} 技术博客封面" />
    {% if page.url and page.url.startsWith('/posts/') %}
      <meta property="article:author" content="{{ site.author }}" />
      <meta property="article:published_time" content="{{ date | isoDate }}" />
      {% if tags %}
        {% for tag in tags %}
          <meta property="article:tag" content="{{ tag }}" />
        {% endfor %}
      {% endif %}
    {% endif %}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="{{ title or site.title }}" />
    <meta name="twitter:description" content="{{ description or site.description }}" />
    <meta name="twitter:image" content="{{ site.image | absoluteUrl(site.url) }}" />
    <meta name="twitter:image:alt" content="{{ site.title }} 技术博客封面" />
    <link rel="alternate" type="application/rss+xml" title="{{ site.title }} RSS" href="{{ '/rss.xml' | url }}" />
    <link rel="stylesheet" href="{{ '/assets/css/style.css' | url }}" />
    {% if page.url and page.url.startsWith('/posts/') %}
      <script type="application/ld+json">
        {{ {
          "@context": "https://schema.org",
          "@type": "BlogPosting",
          "headline": title,
          "description": description,
          "url": page.url | absoluteUrl(site.url),
          "datePublished": date | isoDate,
          "dateModified": date | isoDate,
          "author": {
            "@type": "Person",
            "name": site.author
          },
          "publisher": {
            "@type": "Person",
            "name": site.author
          },
          "image": site.image | absoluteUrl(site.url),
          "mainEntityOfPage": page.url | absoluteUrl(site.url)
        } | jsonify | safe }}
      </script>
    {% else %}
      <script type="application/ld+json">
        {{ {
          "@context": "https://schema.org",
          "@type": "Blog",
          "name": site.title,
          "description": site.description,
          "url": site.url,
          "inLanguage": "zh-CN",
          "author": {
            "@type": "Person",
            "name": site.author
          }
        } | jsonify | safe }}
      </script>
    {% endif %}
  </head>
  <body>
    <div class="ambient-layer" aria-hidden="true"></div>
    <header class="site-header">
      <div class="container nav-wrap">
        <a class="brand" href="{{ '/' | url }}">{{ site.title }}</a>
        <nav class="nav-links" aria-label="主导航">
          <a href="{{ '/' | url }}#latest">文章</a>
          <a href="{{ '/bookmarks/' | url }}">收藏夹</a>
          <a href="{{ '/rss.xml' | url }}">RSS</a>
          <a href="{{ '/about/' | url }}">关于</a>
          <a class="icon-link" href="https://github.com/SimonMing47/codemint-blog" aria-label="GitHub 仓库" title="GitHub 仓库">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2.17c-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.28-1.69-1.28-1.69-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.03 1.75 2.69 1.24 3.34.95.1-.74.4-1.24.73-1.53-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.28 1.18-3.09-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.16 1.18A10.94 10.94 0 0 1 12 6c.98 0 1.95.13 2.87.39 2.19-1.49 3.15-1.18 3.15-1.18.63 1.58.23 2.75.11 3.04.74.81 1.18 1.83 1.18 3.09 0 4.42-2.69 5.39-5.26 5.68.41.36.78 1.06.78 2.14v3.18c0 .31.21.67.8.56A11.52 11.52 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z" />
            </svg>
          </a>
          <button class="icon-button" id="theme-toggle" type="button" aria-label="切换主题" title="切换主题">◐</button>
        </nav>
      </div>
    </header>
    {{ content | safe }}
    <footer class="container footer">
      <p>{{ site.title }} · 编程学习与工程实践 · {{ "" | year }}</p>
    </footer>
    <script src="{{ '/assets/js/main.js' | url }}"></script>
  </body>
</html>
