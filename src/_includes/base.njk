<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ title or site.title }}</title>
    <meta name="description" content="{{ description or site.description }}" />
    <meta name="theme-color" content="#f5f5f7" />
    <meta property="og:title" content="{{ title or site.title }}" />
    <meta property="og:description" content="{{ description or site.description }}" />
    <meta property="og:type" content="{% if page.url and page.url.startsWith('/posts/') %}article{% else %}website{% endif %}" />
    <meta property="og:url" content="{{ page.url | absoluteUrl(site.url) }}" />
    <link rel="alternate" type="application/rss+xml" title="{{ site.title }} RSS" href="{{ '/rss.xml' | url }}" />
    <link rel="stylesheet" href="{{ '/assets/css/style.css' | url }}" />
  </head>
  <body>
    <header class="site-header">
      <div class="container nav-wrap">
        <a class="brand" href="{{ '/' | url }}">{{ site.title }}</a>
        <nav class="nav-links" aria-label="主导航">
          <a href="{{ '/' | url }}#latest">文章</a>
          <a href="{{ '/rss.xml' | url }}">RSS</a>
          <a href="{{ '/' | url }}#about">关于</a>
          <button class="icon-button" id="theme-toggle" type="button" aria-label="切换主题" title="切换主题">◐</button>
        </nav>
      </div>
    </header>
    {{ content | safe }}
    <footer class="container footer">
      <p>{{ site.title }} · Markdown first · {{ "" | year }}</p>
    </footer>
    <script src="{{ '/assets/js/main.js' | url }}"></script>
  </body>
</html>
